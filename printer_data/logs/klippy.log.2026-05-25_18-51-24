	{% endif %}

[gcode_macro START_PRINT]
variable_max_velocity = 0
variable_max_accel = 0
variable_square_corner_velocity = 0
gcode = 
	
	UPDATE_DELAYED_GCODE ID=wait_for_end_print_cooldown DURATION=0
	
	
