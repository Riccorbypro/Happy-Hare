	M140 S0
	{% endif %}
	
	{% if beacon %}
	_BEACON_CONTACT_HOME
	{% elif cartographer_touch %}
	_CARTOGRAPHER_TOUCH_HOME
	{% else %}
	_CARTOGRAPHER_TOUCH
	{% endif %}
	
	
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=touch_started VALUE=False
	
	{% if printer["gcode_macro _SAF_START_PRINT_AFTER_BED_MESH"] != null %}
	_SAF_START_PRINT_AFTER_BED_MESH {rawparams}
	{% endif %}
	
	{% if stop_heaters_for_touch %}
	RESPOND TYPE=command MSG='Starting heaters after touch ...'
	{% set after_touch_wait_for_bed = printer["gcode_macro _START_END_PARAMS"].after_touch_wait_for_bed %}
	{% if after_touch_wait_for_bed %}
	M104 S{preheat_nozzle_temp}
	
	{% if start_print_bed_heating_move_bed_distance > 0 %}
	G0 Z{start_print_bed_heating_move_bed_distance} F1200
	{% endif %}
	M190 S{BED_TEMP}
	M104 S{EXTRUDER_TEMP}
	{% else %}
	M140 S{BED_TEMP}
	M104 S{EXTRUDER_TEMP}
	M190 S{BED_TEMP}
	{% endif %}
	{% endif %}
	{% endif %}
	
	{% if printer["gcode_macro _SAF_SMART_PARK"] != null %}
	_SAF_SMART_PARK {rawparams}
	{% elif printer["gcode_macro SMART_PARK"] != null  %}
	SMART_PARK
	{% else %}
	_SMART_PARK
	{% endif %}
	
	M109 S{EXTRUDER_TEMP}
	
	{% if printer["gcode_macro _SAF_START_PRINT_BEFORE_LINE_PURGE"] != null %}
	_SAF_START_PRINT_BEFORE_LINE_PURGE {rawparams}
	{% endif %}
	
	{% if printer["gcode_macro _SAF_LINE_PURGE"] != null %}
	_SAF_LINE_PURGE {rawparams}
	{% elif printer["gcode_macro LINE_PURGE"] != null  %}
	LINE_PURGE
	{% else %}
	_LINE_PURGE
	{% endif %}
	
	{% if max_velocity > start_max_velocity or max_accel > start_max_accel or square_corner_velocity > start_square_corner_velocity %}
	RESPOND TYPE=command MSG='Restoring VELOCITY={max_velocity} ACCEL={max_accel} SQUARE_CORNER_VELOCITY={square_corner_velocity}'
	SET_VELOCITY_LIMIT VELOCITY={max_velocity} ACCEL={max_accel} SQUARE_CORNER_VELOCITY={square_corner_velocity}
	{% endif %}
	
	{% if printer["gcode_macro _SAF_START_PRINT_END"] != null %}
	_SAF_START_PRINT_END {rawparams}
	{% endif %}
	{% endif %}

[gcode_macro _START_PRINT_BED_MESH]
gcode = 
	{% if 'bed_mesh' in printer.configfile.settings %}
	{% if BED_MESH_PROFILE %}
	BED_MESH_PROFILE LOAD="{BED_MESH_PROFILE}" START_PRINT=1
	{% else %}
	{% set BED_MESH_ADAPTIVE=params.BED_MESH_ADAPTIVE|default(1) %}
	{% set full_bed_mesh_above_percentage_full = printer["gcode_macro _START_END_PARAMS"].full_bed_mesh_above_percentage_full %}
	{% if BED_MESH_ADAPTIVE == 1 and full_bed_mesh_above_percentage_full > 0 %}
	{% set all_points = printer.exclude_object.objects | map(attribute='polygon') | sum(start=[]) %}
	{% if all_points|length > 0 %}
	{% set print_x_min = all_points | map(attribute=0) | min | float %}
	{% set print_x_max = all_points | map(attribute=0) | max | float %}
	{% set print_y_min = all_points | map(attribute=1) | min | float %}
	{% set print_y_max = all_points | map(attribute=1) | max | float %}
	
	{% set print_width = print_x_max - print_x_min %}
	{% set print_depth = print_y_max - print_y_min %}
	{% set print_area = print_width * print_depth %}
	
	
	{% set bed_width = printer.configfile.config.stepper_x.position_max | float %}
	{% set bed_depth = printer.configfile.config.stepper_y.position_max | float %}
	{% set bed_area = bed_width * bed_depth %}
	
	{% set bed_usage = (print_area / bed_area) * 100 %}
	{% if bed_usage >= full_bed_mesh_above_percentage_full %}
	RESPOND TYPE=command MSG="Using full bed mesh (Usage is {bed_usage|round(1)}%)"
	{% set BED_MESH_ADAPTIVE=0 %}
	{% endif %}
	{% endif %}
	{% endif %}
