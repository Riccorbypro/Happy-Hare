	{% endif %}
	
	
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=touch_started VALUE=True
	
	{% set stop_heaters_for_touch = printer["gcode_macro _START_END_PARAMS"].stop_heaters_for_touch %}
