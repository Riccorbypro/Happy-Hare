	M400
	G4 P1000; wait a second so the printer doesn't shake
	CARTOGRAPHER_STREAM ACTION=STOP FILE=/home/riccorbypro/printer_data/config/tapdata2mms.csv
	G1 Z5 F1200
	G28
	G1 Z5 F1200
	M400
	G4 P1000; wait a second so the printer doesn't shake
	CARTOGRAPHER_STREAM ACTION=START FILE=/home/riccorbypro/printer_data/config/tapdata3mms.csv
	G1 Z-0.5 F200
	M400
	G4 P1000; wait a second so the printer doesn't shake
	CARTOGRAPHER_STREAM ACTION=STOP FILE=/home/riccorbypro/printer_data/config/tapdata3mms.csv
	G1 Z10 F800

[gcode_macro _CARTOGRAPHER_VARIABLES]
variable_touch_mode = True
variable_verify_firmware = False
gcode = 

[mcu cartographer]
is_non_critical = true
no_reconnect = true
serial = /dev/serial/by-id/usb-Cartographer_stm32g431xx_3A0047001850303655333520-if00
