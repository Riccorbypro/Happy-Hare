	{% set name = params.SENSOR|default(sensor) %}
	{% set obj  = printer[name] %}
	M118 PSENSOR Enabled: {obj.enabled}  Value: {obj.value|float|round(3)}  Raw Value: {obj.value_raw|float|round(3)}

[gcode_macro MMU_CHANGE_TOOL_STANDALONE]
