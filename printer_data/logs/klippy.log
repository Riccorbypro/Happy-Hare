[gcode_macro LIST_EXCLUDED_OBJECTS]
description = Needed macro for Exclude Objects
gcode = 
	EXCLUDE_OBJECT

[gcode_macro REMOVE_ALL_EXCLUDED]
description = Needed macro for Exclude Objects
gcode = 
	EXCLUDE_OBJECT RESET=1

[gcode_macro LOAD_FILAMENT]
variable_load_distance = 50
variable_purge_distance = 70
gcode = 
	{% set speed = params.SPEED|default(300) %}
	{% set max_velocity = printer.configfile.settings['extruder'].max_extrude_only_velocity  * 60 %}
	SAVE_GCODE_STATE NAME=load_state
	G91
	G92 E0
	G1 E{load_distance} F{max_velocity}
	G1 E{purge_distance} F{speed}
	RESTORE_GCODE_STATE NAME=load_state

[gcode_macro UNLOAD_FILAMENT]
variable_unload_distance = 86
variable_purge_distance = 30
gcode = 
	{% set speed = params.SPEED|default(300) %}
	{% set max_velocity = printer.configfile.settings['extruder'].max_extrude_only_velocity  * 60 %}
	SAVE_GCODE_STATE NAME=unload_state
	CUT_FILAMENT
	G91
	G92 E0
	G1 E{purge_distance} F{speed}
	G1 E-{unload_distance} F{max_velocity}
	RESTORE_GCODE_STATE NAME=unload_state

[gcode_macro CUT_FILAMENT]
gcode = 
	{% if "xy" not in printer.toolhead.homed_axes %}
	G28 X Y
	{% endif %}
	G90
	G0 Y200 F3600
	G0 X200 F6000
	G0 X42 F6000
	G0 X42 Y240 F6000
	SET_VELOCITY_LIMIT ACCEL=30000
	G0 E-2 F120
	G0 X42 Y301 F18000
	G0 Y240 F3600
	G0 E-3 F120
	G0 X42 Y301 F18000
	G0 Y240 F3600
	SET_VELOCITY_LIMIT ACCEL={printer.configfile.settings.printer.max_accel}

