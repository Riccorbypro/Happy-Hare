resistance1 = 260000
temperature2 = 220
resistance2 = 738
temperature3 = 350
resistance3 = 98

[extruder]
step_pin = toolhead:PB7
dir_pin = !toolhead:PB6
enable_pin = !toolhead:PB9
rotation_distance = 5.818
microsteps = 64
full_steps_per_rotation = 200
nozzle_diameter = 0.400
filament_diameter = 1.75
heater_pin = toolhead:PC15
sensor_type = K2P
sensor_pin = toolhead:PB2
pullup_resistor = 4700
min_temp = 0
max_temp = 350
max_power = 0.8
min_extrude_temp = 10
pressure_advance = 0.04
pressure_advance_smooth_time = 0.040
max_extrude_cross_section = 5000.0
max_extrude_only_distance = 1500
control = pid
