max_samples = 15
unsafe_max_touch_temperature = 155
experimental_home_random_radius = 10.0

[axis_twist_compensation]
calibrate_start_x = 11
calibrate_end_x = 290
calibrate_y = 150
calibrate_start_y = 37
calibrate_end_y = 260
z_compensations = 0.006336, -0.045192, -0.038413, 0.007276, 0.069992
compensation_start_x = 11.0
compensation_end_x = 290.0
zy_compensations = 0.027522, 0.021956, -0.026506, -0.025496, 0.002524
compensation_start_y = 37.0
compensation_end_y = 260.0

[bed_mesh]
zero_reference_position = 150,150
speed = 400
horizontal_move_z = 3
mesh_min = 15, 10
mesh_max = 285, 260
probe_count = 20, 20
adaptive_margin = 10
mesh_pps = 2, 2
algorithm = bicubic
bicubic_tension = 0.2
move_check_distance = 5
split_delta_z = .025
fade_start = 1
fade_end = 10
fade_target = 0
scan_overshoot = 8

[temperature_sensor cartographer]
