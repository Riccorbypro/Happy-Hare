gcode = 
	{% if printer.print_stats.state == "printing" %}
	PAUSE
	
	{% if printer["gcode_macro _SAF_ON_FILAMENT_RUNOUT"] != null %}
	_SAF_ON_FILAMENT_RUNOUT
	{% else %}
	RESPOND TYPE=command MSG='Filament Runout detected.'
	{% endif %}
	{% else %}
	RESPOND TYPE=command MSG='Printer already paused.'
	{% endif %}

[gcode_macro START_PRINT]
variable_max_velocity = 0
variable_max_accel = 0
variable_square_corner_velocity = 0
gcode = 
	
	UPDATE_DELAYED_GCODE ID=wait_for_end_print_cooldown DURATION=0
	
	
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=touch_started VALUE=False
	
	
	{% set started_cooldown = printer["gcode_macro END_PRINT"].started_cooldown|default(false) %}
	{% if started_cooldown %}
	SET_GCODE_VARIABLE MACRO=END_PRINT VARIABLE=started_cooldown VALUE=False
	{% if "xyz" in printer.toolhead.homed_axes %}
	M84
	{% endif %}
	TURN_OFF_FANS
	{% endif %}
	
	{% set runout_sensor = printer["gcode_macro _CLIENT_VARIABLE"].runout_sensor|default("") %}
	{% if runout_sensor != "" and printer[runout_sensor] != null %}
	{% set runout_sensor_id = (runout_sensor.split(" "))[1] %}
	SET_FILAMENT_SENSOR SENSOR={runout_sensor_id} ENABLE=1
	{% set filament_detected = printer[runout_sensor].filament_detected %}
	{% else %}
	{% set filament_detected = true %}
	{% endif %}
	
	{% if not filament_detected %}
	RESPOND TYPE=error MSG='Filament not detected, Print aborted! "{runout_sensor_id}" detects no filament, please load filament.'
	RESPOND TYPE=command MSG="action:prompt_begin Print aborted !!!"
	RESPOND TYPE=command MSG='action:prompt_text "{runout_sensor_id}" detects no filament, please load filament.'
	RESPOND TYPE=command MSG="action:prompt_footer_button Ok|RESPOND TYPE=command MSG=action:prompt_end|info"
	RESPOND TYPE=command MSG="action:prompt_show"
	CANCEL_PRINT
	{% else %}
	
	{% set current_bed_temp = printer.heater_bed.temperature %}
	
	{% set BED_TEMP=params.BED_TEMP|default(65)|float %}
	{% set EXTRUDER_TEMP=params.EXTRUDER_TEMP|default(230)|float %}
	
	{% set max_velocity = printer.toolhead.max_velocity %}
	{% set max_accel = printer.toolhead.max_accel %}
	{% set square_corner_velocity = printer.toolhead.square_corner_velocity %}
	{% set start_max_velocity = [printer["gcode_macro _START_END_PARAMS"].start_max_velocity, max_velocity]|min %}
	{% set start_max_accel = [printer["gcode_macro _START_END_PARAMS"].start_max_accel, max_accel]|min %}
	{% set start_square_corner_velocity = [printer["gcode_macro _START_END_PARAMS"].start_square_corner_velocity, square_corner_velocity]|min %}
	{% set preheat_nozzle_temp = printer["gcode_macro _START_END_PARAMS"].start_preheat_nozzle_temp %}
	
	
	SET_GCODE_VARIABLE MACRO=START_PRINT VARIABLE=max_velocity VALUE={max_velocity}
	SET_GCODE_VARIABLE MACRO=START_PRINT VARIABLE=max_accel VALUE={max_accel}
	SET_GCODE_VARIABLE MACRO=START_PRINT VARIABLE=square_corner_velocity VALUE={square_corner_velocity}
	
	{% if printer["gcode_macro _SAF_START_PRINT_START"] != null %}
	_SAF_START_PRINT_START {rawparams}
	{% endif %}
	
	M104 S{preheat_nozzle_temp}
	M140 S{BED_TEMP}
	
	{% if max_velocity > start_max_velocity or max_accel > start_max_accel or square_corner_velocity > start_square_corner_velocity %}
	RESPOND TYPE=command MSG='Setting VELOCITY={start_max_velocity} (was {max_velocity}) ACCEL={start_max_accel} (was {max_accel}) SQUARE_CORNER_VELOCITY={start_square_corner_velocity} (was {square_corner_velocity})'
	SET_VELOCITY_LIMIT VELOCITY={start_max_velocity} ACCEL={start_max_accel} SQUARE_CORNER_VELOCITY={start_square_corner_velocity}
	{% endif %}
	
	
	
	{% if started_cooldown or "xyz" not in printer.toolhead.homed_axes %}
	{% if printer["gcode_macro _SAF_START_PRINT_BEFORE_G28"] != null %}
	_SAF_START_PRINT_BEFORE_G28 {rawparams}
	{% endif %}
	G28
	{% endif %}
	
	{% set start_print_bed_heating_move_bed_distance = printer["gcode_macro _START_END_PARAMS"].start_print_bed_heating_move_bed_distance %}
	{% if start_print_bed_heating_move_bed_distance > 0 %}
	G0 Z{start_print_bed_heating_move_bed_distance} F1200
	{% endif %}
	
	{% if printer["gcode_macro _SAF_START_PRINT_AFTER_G28"] != null %}
	_SAF_START_PRINT_AFTER_G28 {rawparams}
	{% endif %}
	
	M190 S{BED_TEMP}
	
	_WARP_STABILISE TARGET_TEMP={BED_TEMP} CURRENT_TEMP={current_bed_temp}
	
	{% if printer["gcode_macro _SAF_START_PRINT_BEFORE_BED_MESH"] != null %}
	_SAF_START_PRINT_BEFORE_BED_MESH {rawparams}
	{% endif %}
	
	{% if 'bed_mesh' in printer.configfile.settings %}
	BED_MESH_CLEAR
	{% endif %}
	
	{% set eddyng = ('probe_eddy_ng btt_eddy' in printer.configfile.settings) %}
	{% if eddyng %}
	M109 S{preheat_nozzle_temp}
	
	{% if printer["gcode_macro _SAF_NOZZLE_WIPE"] != null %}
	_SAF_NOZZLE_WIPE {rawparams}
	{% endif %}
	
	
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=touch_started VALUE=True
	
	{% set stop_heaters_for_touch = printer["gcode_macro _START_END_PARAMS"].stop_heaters_for_touch %}
	{% if stop_heaters_for_touch %}
	_START_PRINT_TOUCH_STATE BED_TARGET={BED_TEMP} EXTRUDER_TARGET={preheat_nozzle_temp}
	RESPOND TYPE=command MSG='Stopping heaters before touch ...'
	M104 S0
	M140 S0
	{% endif %}
	
	_PROBE_EDDY_NG_TAP_HOME
	
	
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=touch_started VALUE=False
	
	{% if stop_heaters_for_touch %}
	RESPOND TYPE=command MSG='Starting heaters after touch ...'
	M140 S{BED_TEMP}
	M104 S{preheat_nozzle_temp}
	M190 S{BED_TEMP}
	M109 S{preheat_nozzle_temp}
	{% endif %}
	{% endif %}
	
	_START_PRINT_BED_MESH {rawparams}
	
	{% set beacon = ('beacon' in printer.configfile.settings) %}
	{% set cartotouch = ('scanner' in printer.configfile.settings and 'touch' == printer.configfile.settings['scanner'].mode|default('touch')) %}
	{% set cartographer_touch = (printer["gcode_macro _CARTOGRAPHER_VARIABLES"] != null and printer["gcode_macro _CARTOGRAPHER_VARIABLES"].touch_mode) %}
	{% if cartotouch or beacon or cartographer_touch %}
	M109 S{preheat_nozzle_temp}
	
	{% if printer["gcode_macro _SAF_NOZZLE_WIPE"] != null %}
	_SAF_NOZZLE_WIPE {rawparams}
	{% endif %}
	
	
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=touch_started VALUE=True
	
	{% set stop_heaters_for_touch = printer["gcode_macro _START_END_PARAMS"].stop_heaters_for_touch %}
	{% if stop_heaters_for_touch %}
	_START_PRINT_TOUCH_STATE BED_TARGET={BED_TEMP} EXTRUDER_TARGET={preheat_nozzle_temp}
	RESPOND TYPE=command MSG='Stopping heaters before touch ...'
	M104 S0
	M140 S0
	{% endif %}
	
	{% if beacon %}
	_BEACON_CONTACT_HOME
	{% elif cartographer_touch %}
	_CARTOGRAPHER_TOUCH_HOME
	{% else %}
	_CARTOGRAPHER_TOUCH
	{% endif %}
	
	
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=touch_started VALUE=False
	
	{% if printer["gcode_macro _SAF_START_PRINT_AFTER_BED_MESH"] != null %}
	_SAF_START_PRINT_AFTER_BED_MESH {rawparams}
	{% endif %}
	
	{% if stop_heaters_for_touch %}
	RESPOND TYPE=command MSG='Starting heaters after touch ...'
	{% set after_touch_wait_for_bed = printer["gcode_macro _START_END_PARAMS"].after_touch_wait_for_bed %}
	{% if after_touch_wait_for_bed %}
	M104 S{preheat_nozzle_temp}
	
	{% if start_print_bed_heating_move_bed_distance > 0 %}
	G0 Z{start_print_bed_heating_move_bed_distance} F1200
	{% endif %}
	M190 S{BED_TEMP}
	M104 S{EXTRUDER_TEMP}
	{% else %}
	M140 S{BED_TEMP}
	M104 S{EXTRUDER_TEMP}
	M190 S{BED_TEMP}
	{% endif %}
	{% endif %}
	{% endif %}
	
	{% if printer["gcode_macro _SAF_SMART_PARK"] != null %}
	_SAF_SMART_PARK {rawparams}
	{% elif printer["gcode_macro SMART_PARK"] != null  %}
	SMART_PARK
	{% else %}
	_SMART_PARK
	{% endif %}
	
	M109 S{EXTRUDER_TEMP}
	
	{% if printer["gcode_macro _SAF_START_PRINT_BEFORE_LINE_PURGE"] != null %}
	_SAF_START_PRINT_BEFORE_LINE_PURGE {rawparams}
	{% endif %}
	
	{% if printer["gcode_macro _SAF_LINE_PURGE"] != null %}
	_SAF_LINE_PURGE {rawparams}
	{% elif printer["gcode_macro LINE_PURGE"] != null  %}
	LINE_PURGE
	{% else %}
	_LINE_PURGE
	{% endif %}
	
	{% if max_velocity > start_max_velocity or max_accel > start_max_accel or square_corner_velocity > start_square_corner_velocity %}
	RESPOND TYPE=command MSG='Restoring VELOCITY={max_velocity} ACCEL={max_accel} SQUARE_CORNER_VELOCITY={square_corner_velocity}'
	SET_VELOCITY_LIMIT VELOCITY={max_velocity} ACCEL={max_accel} SQUARE_CORNER_VELOCITY={square_corner_velocity}
	{% endif %}
	
	{% if printer["gcode_macro _SAF_START_PRINT_END"] != null %}
	_SAF_START_PRINT_END {rawparams}
	{% endif %}
	{% endif %}

[gcode_macro _START_PRINT_BED_MESH]
gcode = 
	{% if 'bed_mesh' in printer.configfile.settings %}
	{% if BED_MESH_PROFILE %}
	BED_MESH_PROFILE LOAD="{BED_MESH_PROFILE}" START_PRINT=1
	{% else %}
	{% set BED_MESH_ADAPTIVE=params.BED_MESH_ADAPTIVE|default(1) %}
	{% set full_bed_mesh_above_percentage_full = printer["gcode_macro _START_END_PARAMS"].full_bed_mesh_above_percentage_full %}
	{% if BED_MESH_ADAPTIVE == 1 and full_bed_mesh_above_percentage_full > 0 %}
	{% set all_points = printer.exclude_object.objects | map(attribute='polygon') | sum(start=[]) %}
	{% if all_points|length > 0 %}
	{% set print_x_min = all_points | map(attribute=0) | min | float %}
	{% set print_x_max = all_points | map(attribute=0) | max | float %}
	{% set print_y_min = all_points | map(attribute=1) | min | float %}
	{% set print_y_max = all_points | map(attribute=1) | max | float %}
	
	{% set print_width = print_x_max - print_x_min %}
	{% set print_depth = print_y_max - print_y_min %}
	{% set print_area = print_width * print_depth %}
	
	
	{% set bed_width = printer.configfile.config.stepper_x.position_max | float %}
	{% set bed_depth = printer.configfile.config.stepper_y.position_max | float %}
	{% set bed_area = bed_width * bed_depth %}
	
	{% set bed_usage = (print_area / bed_area) * 100 %}
	{% if bed_usage >= full_bed_mesh_above_percentage_full %}
	RESPOND TYPE=command MSG="Using full bed mesh (Usage is {bed_usage|round(1)}%)"
	{% set BED_MESH_ADAPTIVE=0 %}
	{% endif %}
	{% endif %}
	{% endif %}
	BED_MESH_CALIBRATE ADAPTIVE={BED_MESH_ADAPTIVE} START_PRINT=1
	{% if printer["gcode_macro _SAF_START_PRINT_AFTER_BED_MESH"] != null %}
	_SAF_START_PRINT_AFTER_BED_MESH {rawparams}
	{% endif %}
	{% endif %}
	{% endif %}

[gcode_macro _TOOLHEAD_PARK_CANCEL_END_PRINT]
gcode = 
	{% set cooldown = params.COOLDOWN | default(None) %}
	{% set skip_z_park = params.SKIP_Z_PARK | default(None) %}
	
	{% if "xyz" in printer.toolhead.homed_axes %}
	{% set client = printer['gcode_macro _CLIENT_VARIABLE'] | default({}) %}
	{% set velocity = printer.configfile.settings.pause_resume.recover_velocity %}
	{% set sp_move = client.speed_move | default(velocity) * 60 %}
	{% set park_at_cancel_x = client.park_at_cancel_x %}
	
	G90
	{% if not skip_z_park %}
	{% set sp_hop = client.speed_hop | default(15) * 60 %}
	{% set park_dz = client.custom_park_dz | default(2.0) | abs %}
	{% set origin = printer.gcode_move.homing_origin %}
	{% set act = printer.gcode_move.gcode_position %}
	{% set max = printer.toolhead.axis_maximum %}
	{% set z_park = [[(act.z + park_dz), 0]|max, (max.z - origin.z)] | min %}
	
	G1 Z{z_park} F{sp_hop}
	{% endif %}
	{% if cooldown %}
	{% set park_at_cancel_y = printer.configfile.settings['stepper_y'].position_max / 2 %}
	{% else %}
	{% set park_at_cancel_y = client.park_at_cancel_y %}
	{% endif %}
	G0 X{park_at_cancel_x} Y{park_at_cancel_y} F{sp_move}
	
	{% if not printer.gcode_move.absolute_coordinates %}
	G91
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='Printer not homed'
	{% endif %}

[gcode_macro END_PRINT]
variable_started_cooldown = False
gcode = 
	{% set bed_warp_stabilisation = printer['output_pin Bed_Warp_Stabilisation'].value == 1 %}
	{% set end_print_cool_down = printer["gcode_macro _START_END_PARAMS"].end_print_cool_down %}
	{% set end_print_cool_down_nozzle_temp = printer["gcode_macro _START_END_PARAMS"].end_print_cool_down_nozzle_temp|float %}
	{% set end_print_cool_down_max_bed_temp = printer["gcode_macro _START_END_PARAMS"].end_print_cool_down_max_bed_temp|float %}
	{% set end_print_keep_bed_heated = printer["gcode_macro _START_END_PARAMS"].end_print_keep_bed_heated %}
	{% set eddyng = ('probe_eddy_ng btt_eddy' in printer.configfile.settings) %}
	{% set runout_sensor = printer["gcode_macro _CLIENT_VARIABLE"].runout_sensor|default("") %}
	
	
	SET_GCODE_VARIABLE MACRO=END_PRINT VARIABLE=started_cooldown VALUE=False
	
	_RESTORE_VELOCITY_ACCEL
	
	{% if 'bed_mesh' in printer.configfile.settings %}
	BED_MESH_CLEAR
	{% endif %}
	
	{% if eddyng %}
	PROBE_EDDY_NG_SET_TAP_OFFSET VALUE=0
	{% endif %}
	
	{% set current_bed_temp = printer.heater_bed.temperature %}
	
	{% if printer["gcode_macro _SAF_END_PRINT_START"] != null %}
	_SAF_END_PRINT_START
	{% endif %}
	
	{% if runout_sensor != "" %}
	{% set runout_sensor_id = (runout_sensor.split(" "))[1] %}
	SET_FILAMENT_SENSOR SENSOR={runout_sensor_id} ENABLE=0
	{% endif %}
	
	{% set cancel_retract = printer['gcode_macro _CLIENT_VARIABLE'].cancel_retract %}
	_CLIENT_RETRACT LENGTH={cancel_retract}
	
	
	{% if end_print_cool_down and current_bed_temp < end_print_cool_down_max_bed_temp %}
	_TOOLHEAD_PARK_CANCEL_END_PRINT COOLDOWN=1
	{% else %}
	_TOOLHEAD_PARK_CANCEL_END_PRINT
	{% endif %}
	
	{% if bed_warp_stabilisation and end_print_keep_bed_heated %}
	RESPOND TYPE=command MSG='Heat bed waiting for next print'
	M104 S0
	{% else %}
	TURN_OFF_HEATERS
	{% endif %}
	
	
	SET_PAUSE_NEXT_LAYER ENABLE=0
	SET_PAUSE_AT_LAYER ENABLE=0 LAYER=0
	
	{% if end_print_cool_down and current_bed_temp < end_print_cool_down_max_bed_temp %}
	RESPOND TYPE=command MSG='Waiting for nozzle temp to be below {end_print_cool_down_nozzle_temp}c'
	
	{% if 'fan_generic auxiliary' in printer.configfile.settings %}
	SET_FAN_SPEED FAN=auxiliary SPEED=0.5
	{% endif %}
	
	M106 S180
	
	
	SET_GCODE_VARIABLE MACRO=END_PRINT VARIABLE=started_cooldown VALUE=True
	UPDATE_DELAYED_GCODE ID=wait_for_end_print_cooldown DURATION=1
	{% else %}
	M84
	TURN_OFF_FANS
	
	{% if printer["gcode_macro _SAF_END_PRINT_END"] != null %}
	_SAF_END_PRINT_END
	{% endif %}
	{% endif %}

[delayed_gcode wait_for_end_print_cooldown]
gcode = 
	{% set end_print_cool_down_nozzle_temp = printer["gcode_macro _START_END_PARAMS"].end_print_cool_down_nozzle_temp|float %}
	{% if printer.extruder.temperature <= end_print_cool_down_nozzle_temp %}
	_WAIT_TEMP_COOL_DOWN_END
	{% else %}
	UPDATE_DELAYED_GCODE ID=wait_for_end_print_cooldown DURATION=5
	{% endif %}

[gcode_macro _WAIT_TEMP_COOL_DOWN_END]
gcode = 
	UPDATE_DELAYED_GCODE ID=wait_for_end_print_cooldown DURATION=0
	
	
	_TOOLHEAD_PARK_CANCEL_END_PRINT SKIP_Z_PARK=1
	
	M84
	TURN_OFF_FANS
	
	SET_GCODE_VARIABLE MACRO=END_PRINT VARIABLE=started_cooldown VALUE=False
	
	{% if printer["gcode_macro _SAF_END_PRINT_END"] != null %}
	_SAF_END_PRINT_END
	{% endif %}

[gcode_macro _RESTORE_VELOCITY_ACCEL]
gcode = 
	{% set max_velocity = printer.toolhead.max_velocity %}
	{% set max_accel = printer.toolhead.max_accel %}
	{% set square_corner_velocity = printer.toolhead.square_corner_velocity %}
	{% set start_max_velocity = printer["gcode_macro START_PRINT"].max_velocity %}
	{% set start_max_accel = printer["gcode_macro START_PRINT"].max_accel %}
	{% set start_square_corner_velocity = printer["gcode_macro START_PRINT"].square_corner_velocity %}
	{% if start_max_velocity > 0 and start_max_accel > 0 and start_square_corner_velocity > 0 and (max_velocity != start_max_velocity or max_accel != start_max_accel or square_corner_velocity != start_square_corner_velocity) %}
	RESPOND TYPE=command MSG='Restoring VELOCITY={start_max_velocity} (was {max_velocity}) ACCEL={start_max_accel} (was {max_accel}) SQUARE_CORNER_VELOCITY={start_square_corner_velocity} (was {square_corner_velocity})'
	SET_VELOCITY_LIMIT VELOCITY={start_max_velocity} ACCEL={start_max_accel} SQUARE_CORNER_VELOCITY={start_square_corner_velocity}
	{% endif %}

[gcode_macro _WARP_STABILISE]
description = "Performs bed warp stabilisation based on the current bed temperature. Adjusts stabilisation time according to the bed temperature."
gcode = 
	{% set bed_warp_stabilisation = printer['output_pin Bed_Warp_Stabilisation'].value == 1 %}
	{% if bed_warp_stabilisation %}
	{% set current_temp = params.CURRENT_TEMP|float %}
	{% set target_temp = params.TARGET_TEMP|float %}
	{% if current_temp < (target_temp * 0.99) %}
	{% set multiplier = printer["gcode_macro _START_END_PARAMS"].bed_warp_wait_multiplier|float %}
	{% set interval = printer["gcode_macro _START_END_PARAMS"].bed_warp_wait_interval|int %}
	{% set partial = printer["gcode_macro _START_END_PARAMS"].bed_warp_fraction_wait|float %}
	
	{% if current_temp > (target_temp * partial) %}
	{% set total_time = ((target_temp - current_temp) * multiplier)|int %}
	{% else %}
	
	{% set total_time = (target_temp * multiplier)|int %}
	{% endif %}
	
	RESPOND TYPE=command MSG='Bed Warp Stabilisation starting with a total time of {total_time} seconds...'
	
	{% set loops = (total_time / interval)|int %}
	{% for i in range(loops) %}
	{% set time_remaining = total_time - (i + 1) * interval %}
	RESPOND TYPE=command MSG='Bed Warp Stabilization { time_remaining } seconds remaining'
	{% if time_remaining < interval %}
	G4 P{ time_remaining * 1000 }
	{% else %}
	G4 P{ interval * 1000 }
	{% endif %}
	{% endfor %}
	
	RESPOND TYPE=command MSG='Warp Stabilisation complete!'
	{% else %}
	RESPOND TYPE=command MSG='Skipping bed warp stabilisation as bed already at {current_temp}c'
	{% endif %}
	{% else %}
	RESPOND TYPE=command MSG='Skipping bed warp stabilisation - it is disabled'
	{% endif %}

[gcode_macro _LINE_PURGE]
description = A purge macro that adapts to be near your actual printed objects
gcode = 
	{% set travel_speed = (printer.toolhead.max_velocity) * 30 | float %}
	{% set z_height = printer["gcode_macro _KAMP_Settings"].line_purge_z_hop | float %}
	{% set purge_height = printer["gcode_macro _KAMP_Settings"].purge_height | float %}
	{% set tip_distance = printer["gcode_macro _KAMP_Settings"].tip_distance | float %}
	{% set purge_margin = printer["gcode_macro _KAMP_Settings"].purge_margin | float %}
	{% set purge_amount = printer["gcode_macro _KAMP_Settings"].purge_amount | float %}
	{% set retract_amount = printer["gcode_macro _KAMP_Settings"].line_purge_retract | float %}
	{% set retract_speed = (printer["gcode_macro _KAMP_Settings"].line_purge_retract_speed * 60) | float %}
	{% set flow_rate = printer["gcode_macro _KAMP_Settings"].flow_rate | float %}
	
	
	{% set all_points = printer.exclude_object.objects | map(attribute='polygon') | sum(start=[]) %}
	{% set purge_x_min = (all_points | map(attribute=0) | min | default(0)) %}
	{% set purge_x_max = (all_points | map(attribute=0) | max | default(0)) %}
	{% set purge_y_min = (all_points | map(attribute=1) | min | default(0)) %}
	{% set purge_y_max = (all_points | map(attribute=1) | max | default(0)) %}
	
	{% set purge_x_center = ([((purge_x_max + purge_x_min) / 2) - (purge_amount / 2), 0] | max) %}
	{% set purge_y_center = ([((purge_y_max + purge_y_min) / 2) - (purge_amount / 2), 0] | max) %}
	
	{% set purge_x_origin = ([purge_x_min - purge_margin, 0] | max) %}
	{% set purge_y_origin = ([purge_y_min - purge_margin, 0] | max) %}
	
	{% set purge_move_speed = (flow_rate / 5.0) * 60 | float %}
	
	{% if purge_y_origin > 0 %}
	{action_respond_info("Line purge starting at {}, {} and purging {}mm of filament, requested flow rate is {}mm3/s.".format(
	(purge_x_center),
	(purge_y_origin),
	(purge_amount),
	(flow_rate),
	)) }
	{% else %}
	{action_respond_info("Line purge starting at {}, {} and purging {}mm of filament, requested flow rate is {}mm3/s.".format(
	(purge_x_origin),
	(purge_y_center),
	(purge_amount),
	(flow_rate),
	)) }
	{% endif %}
	
	SAVE_GCODE_STATE NAME=Prepurge_State
	
	{% if purge_y_origin > 0 %}
	G92 E0
	G0 F{travel_speed}
	G90
	G0 X{purge_x_center} Y{purge_y_origin}
	G0 Z{purge_height}
	M83
	G1 E{tip_distance} F{purge_move_speed}
	G1 X{purge_x_center + purge_amount} E{purge_amount} F{purge_move_speed}
	G1 E-{retract_amount} F{retract_speed}
	G0 X{purge_x_center + purge_amount + 10} F{travel_speed}
	G92 E0
	M82
	G0 Z{z_height} F{travel_speed}
	{% else %}
	G92 E0
	G0 F{travel_speed}
	G90
	G0 X{purge_x_origin} Y{purge_y_center}
	G0 Z{purge_height}
	M83
	G1 E{tip_distance} F{purge_move_speed}
	G1 Y{purge_y_center + purge_amount} E{purge_amount} F{purge_move_speed}
	G1 E-{retract_amount} F{retract_speed}
	G0 Y{purge_y_center + purge_amount + 10} F{travel_speed}
	G92 E0
	M82
	G0 Z{z_height} F{travel_speed}
	{% endif %}
	
	RESTORE_GCODE_STATE NAME=Prepurge_State

[gcode_macro _SMART_PARK]
description = Parks your printhead over the start of line purge
gcode = 
	
	{% set travel_speed = (printer.toolhead.max_velocity) * 30 | float %}
	
	
	{% set z_height = printer["gcode_macro _KAMP_Settings"].smart_park_height | float %}
	{% set purge_margin = printer["gcode_macro _KAMP_Settings"].purge_margin | float %}
	{% set purge_amount = printer["gcode_macro _KAMP_Settings"].purge_amount | float %}
	
	
	{% set all_points = printer.exclude_object.objects | map(attribute='polygon') | sum(start=[]) %}
	{% set purge_x_min = (all_points | map(attribute=0) | min | default(0)) %}
	{% set purge_x_max = (all_points | map(attribute=0) | max | default(0)) %}
	{% set purge_y_min = (all_points | map(attribute=1) | min | default(0)) %}
	{% set purge_y_max = (all_points | map(attribute=1) | max | default(0)) %}
	
	{% set purge_x_center = ([((purge_x_max + purge_x_min) / 2) - (purge_amount / 2), 0] | max) %}
	{% set purge_y_center = ([((purge_y_max + purge_y_min) / 2) - (purge_amount / 2), 0] | max) %}
	
	{% set purge_x_origin = ([purge_x_min - purge_margin, 0] | max) %}
	{% set purge_y_origin = ([purge_y_min - purge_margin, 0] | max) %}
	
	{% if purge_y_origin > 0 %}
	{ action_respond_info("Smart Park location: {},{}.".format(
	(purge_x_center),
	(purge_y_origin),
	)) }
	{% else %}
	{ action_respond_info("Smart Park location: {},{}.".format(
	(purge_x_origin),
	(purge_y_center),
	)) }
	{% endif %}
	
	SAVE_GCODE_STATE NAME=Prepurge_State
	
	{% if purge_y_origin > 0 %}
	G92 E0
	G0 F{travel_speed}
	G90
	G0 X{purge_x_center} Y{purge_y_origin}
	G0 Z{z_height}
	{% else %}
	G92 E0
	G0 F{travel_speed}
	G90
	G0 X{purge_x_origin} Y{purge_y_center}
	G0 Z{z_height}
	{% endif %}
	
	RESTORE_GCODE_STATE NAME=Prepurge_State

[gcode_macro TURN_OFF_FANS]
description = Stop auxiliary and part fan
gcode = 
	M107
	{% if 'fan_generic auxiliary' in printer.configfile.settings %}
	SET_FAN_SPEED FAN=auxiliary SPEED=0
	{% endif %}

[gcode_macro TURN_ON_FANS]
description = Turn on auxiliary and part fan
gcode = 
	M106 S255
	{% if 'fan_generic auxiliary' in printer.configfile.settings %}
	SET_FAN_SPEED FAN=auxiliary SPEED=1
	{% endif %}

[gcode_macro M141]
description = Set Chamber Temperature with slicers
gcode = 
	{% if 'S' in params|upper %}
	{% if printer["temperature_fan chamber_fan"].speed > 0.0 %}
	M106 P1 S255
	{% else %}
	M106 P1 S0
	{% endif %}
	{% if params.S|int > 0 %}
	SET_TEMPERATURE_FAN_TARGET TEMPERATURE_FAN=chamber_fan TARGET={params.S|default(35)}
	{% else %}
	SET_TEMPERATURE_FAN_TARGET TEMPERATURE_FAN=chamber_fan TARGET=35
	{% if params.S|int == 0 %}
	M106 P1 S0
	{% endif %}
	{% endif %}
	{% endif %}
	{% if printer["heater_generic chamber"] is defined %}
	{% if params.S|int > 35 %}
	{% set requested_temp = params.S|int|default(35) %}
	{% set actual_temp = requested_temp - 5 %}
	SET_HEATER_TEMPERATURE HEATER=chamber TARGET={ [actual_temp, 35]|max }
	{% else %}
	SET_HEATER_TEMPERATURE HEATER=chamber TARGET=0
	{% endif %}
	{% endif %}

[gcode_macro QUICK_START]
description = "Quick Start Calibration"
gcode = 
	RESPOND TYPE=command MSG="action:prompt_begin Quick Start Calibration"
	{% set kinematics = printer.configfile.settings['printer'].kinematics %}
	{% if kinematics == 'corexy' %}
	RESPOND TYPE=command MSG="action:prompt_text This will run the basic calibrations required to start using your printer. Quick Start includes basic input shaping and PID calibration for both the bed and hot end.  Do not touch the machine during this process, as it will yield inaccurate results."
	RESPOND TYPE=command MSG="action:prompt_text This process can take approximately 30 to 40 minutes. Once complete, you will be prompted with a new dialog window to save these changes."
	{% else %}
	RESPOND TYPE=command MSG="action:prompt_text This will run pid calibrations required to start using your printer. Quick Start includes PID calibration for both the bed and hot end."
	RESPOND TYPE=command MSG="action:prompt_text This process can take approximately 20 to 30 minutes. Once complete, you will be prompted with a new dialog window to save these changes."
	{% endif %}
	
	RESPOND TYPE=command MSG="action:prompt_button Start Calibration |_QUICK_START"
	RESPOND TYPE=command MSG="action:prompt_footer_button Close|RESPOND TYPE=command MSG=action:prompt_end"
	RESPOND TYPE=command MSG="action:prompt_show"

[gcode_macro _QUICK_START]
gcode = 
	RESPOND TYPE=command MSG="action:prompt_end"
	RESPOND TYPE=command MSG='Quick start - Starting Quick Start Calibration'
	
	{% if "xyz" not in printer.toolhead.homed_axes %}
	G28
	{% endif %}
	
	{% set kinematics = printer.configfile.settings['printer'].kinematics %}
	{% if kinematics == 'corexy' %}
	RESPOND TYPE=command MSG='Quick start - Shaper Calibration'
	SHAPER_CALIBRATE
	{% else %}
	RESPOND TYPE=command MSG='Quick start - Skipping Shaper Calibration for non Core-XY printer'
	{% endif %}
	
	RESPOND TYPE=command MSG='Quick start - PID tuning Bed at 65C'
	PID_CALIBRATE_BED BED_TEMP=65
	RESPOND TYPE=command MSG='Quick start - PID tuning Hotend at 230C'
	PID_CALIBRATE_HOTEND HOTEND_TEMP=230
	
	RESPOND TYPE=command MSG='------------- Quick Start Complete! -------------'
	_QUICK_START_COMPLETE

[gcode_macro _QUICK_START_COMPLETE]
gcode = 
	RESPOND TYPE=command MSG="action:prompt_begin Quick Start Complete"
	{% set kinematics = printer.configfile.settings['printer'].kinematics %}
	{% if kinematics == 'corexy' %}
	RESPOND TYPE=command MSG="action:prompt_text Quick Start calibration has been completed. The printer's PID and input shaping values will be saved upon pressing the save and restart button."
	{% else %}
	RESPOND TYPE=command MSG="action:prompt_text Quick Start calibration has been completed. The printer's PID values will be saved upon pressing the save and restart button."
	{% endif %}
	RESPOND TYPE=command MSG="action:prompt_button Save and Restart |_QUICK_START_SAVE"
	RESPOND TYPE=command MSG="action:prompt_footer_button Close|RESPOND TYPE=command MSG=action:prompt_end"
	RESPOND TYPE=command MSG="action:prompt_show"

[gcode_macro _QUICK_START_SAVE]
gcode = 
	RESPOND TYPE=command MSG="action:prompt_end"
	SAVE_CONFIG

[gcode_macro _CARTOGRAPHER_TOUCH_HOME]
variable_stop_start_camera = False
gcode = 
	{% set camera_started = printer["gcode_macro START_CAMERA"].started|default(true) %}
	{% if stop_start_camera and camera_started %}
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=camera_stopped VALUE=True
	STOP_CAMERA
	{% endif %}
	
	
	CARTOGRAPHER_TOUCH_HOME
	
	{% if stop_start_camera and camera_started %}
	SET_GCODE_VARIABLE MACRO=_START_PRINT_TOUCH_STATE VARIABLE=camera_stopped VALUE=False
	START_CAMERA
	{% endif %}

[gcode_macro CARTOGRAPHER_SCAN_CALIBRATE]
rename_existing = _CARTOGRAPHER_SCAN_CALIBRATE
gcode = 
	{% set is_disconnected = printer["mcu cartographer"] != null and printer["mcu cartographer"].non_critical_disconnected|default(False) %}
	{% set verify_firmware = printer["gcode_macro _CARTOGRAPHER_VARIABLES"].verify_firmware %}
	{% set mcu_version = printer['mcu cartographer'].mcu_version|default('') %}
	{% if is_disconnected %}
	RESPOND TYPE=error MSG='Cartographer is not connected, aborting calibration!'
	{% elif verify_firmware and 'K1' not in mcu_version and 'Lite' not in mcu_version %}
	RESPOND TYPE=error MSG="Calibration Aborted: You must flash the cartographer with K1 specific firmware!"
	RESPOND TYPE=error MSG="See https://pellcorp.github.io/creality-wiki/invalid-cartographer-firmware"
	{% else %}
	_CARTOGRAPHER_SCAN_CALIBRATE {rawparams}
	{% endif %}

[gcode_macro CARTOGRAPHER_TOUCH_CALIBRATE]
rename_existing = _CARTOGRAPHER_TOUCH_CALIBRATE
gcode = 
	{% set verify_firmware = printer["gcode_macro _CARTOGRAPHER_VARIABLES"].verify_firmware %}
	{% set mcu_version = printer['mcu cartographer'].mcu_version|default('') %}
	{% set is_disconnected = printer["mcu cartographer"] != null and printer["mcu cartographer"].non_critical_disconnected|default(False) %}
	{% if is_disconnected %}
	RESPOND TYPE=error MSG='Cartographer is not connected, aborting calibration!'
	{% elif verify_firmware and 'K1' not in mcu_version and 'Lite' not in mcu_version %}
	RESPOND TYPE=error MSG="Calibration Aborted: You must flash the cartographer with K1 specific firmware!"
	RESPOND TYPE=error MSG="See https://pellcorp.github.io/creality-wiki/invalid-cartographer-firmware"
	{% else %}
	_CARTOGRAPHER_TOUCH_CALIBRATE {rawparams}
	{% endif %}

[gcode_macro BED_MESH_CALIBRATE]
rename_existing = _BED_MESH_CALIBRATE
variable_stop_start_camera = False
gcode = 
	{% set verify_firmware = printer["gcode_macro _CARTOGRAPHER_VARIABLES"].verify_firmware %}
	{% set mcu_version = printer['mcu cartographer'].mcu_version|default('') %}
	{% set is_disconnected = printer["mcu cartographer"] != null and printer["mcu cartographer"].non_critical_disconnected|default(False) %}
	{% if is_disconnected %}
	RESPOND TYPE=error MSG='Cartographer is not connected, aborting calibration!'
	{% elif verify_firmware and 'K1' not in mcu_version and 'Lite' not in mcu_version %}
	RESPOND TYPE=error MSG="Bed Mesh Calibrate Aborted: You must flash the cartographer with K1 specific firmware!"
	RESPOND TYPE=error MSG="See https://pellcorp.github.io/creality-wiki/invalid-cartographer-firmware"
	{% else %}
	{% if printer["gcode_macro _SAF_BED_MESH_START"] != null %}
	_SAF_BED_MESH_START
	{% endif %}
	
	{% set camera_started = printer["gcode_macro START_CAMERA"].started|default(true) %}
	{% if stop_start_camera and camera_started %}
	STOP_CAMERA
	{% endif %}
	
	{% set start_print = (params.START_PRINT|default(0) == '1') %}
	{% if not start_print %}
	{% set max_velocity = printer.toolhead.max_velocity %}
	{% set max_accel = printer.toolhead.max_accel %}
	{% set square_corner_velocity = printer.toolhead.square_corner_velocity %}
	{% set start_max_velocity = [printer["gcode_macro _START_END_PARAMS"].start_max_velocity, max_velocity]|min %}
	{% set start_max_accel = [printer["gcode_macro _START_END_PARAMS"].start_max_accel, max_accel]|min %}
	{% set start_square_corner_velocity = [printer["gcode_macro _START_END_PARAMS"].start_square_corner_velocity, square_corner_velocity]|min %}
	
	{% if max_velocity > start_max_velocity or max_accel > start_max_accel or square_corner_velocity > start_square_corner_velocity %}
	RESPOND TYPE=command MSG='Setting VELOCITY={start_max_velocity} (was {max_velocity}) ACCEL={start_max_accel} (was {max_accel}) SQUARE_CORNER_VELOCITY={start_square_corner_velocity} (was {square_corner_velocity})'
	SET_VELOCITY_LIMIT VELOCITY={start_max_velocity} ACCEL={start_max_accel} SQUARE_CORNER_VELOCITY={start_square_corner_velocity}
	{% endif %}
	{% endif %}
	
	G4 P1000
	
	{% set filtered_params = rawparams | replace("START_PRINT=1", "") | trim %}
	_BED_MESH_CALIBRATE {filtered_params}
	G4 P1000
	
	{% if not start_print %}
	{% if max_velocity > start_max_velocity or max_accel > start_max_accel or square_corner_velocity > start_square_corner_velocity %}
	RESPOND TYPE=command MSG='Restoring VELOCITY={max_velocity} ACCEL={max_accel} SQUARE_CORNER_VELOCITY={square_corner_velocity}'
	SET_VELOCITY_LIMIT VELOCITY={max_velocity} ACCEL={max_accel} SQUARE_CORNER_VELOCITY={square_corner_velocity}
	{% endif %}
	{% endif %}
	
	{% if stop_start_camera and camera_started %}
	START_CAMERA
	{% endif %}
	
	{% if printer["gcode_macro _SAF_BED_MESH_END"] != null %}
	_SAF_BED_MESH_END
	{% endif %}
	{% endif %}

[gcode_macro CARTOGRAPHER_AXIS_TWIST_COMPENSATION]
rename_existing = _CARTOGRAPHER_AXIS_TWIST_COMPENSATION
variable_stop_start_camera = False
gcode = 
	{% set verify_firmware = printer["gcode_macro _CARTOGRAPHER_VARIABLES"].verify_firmware %}
	{% set mcu_version = printer['mcu cartographer'].mcu_version|default('') %}
	{% set is_disconnected = printer["mcu cartographer"] != null and printer["mcu cartographer"].non_critical_disconnected|default(False) %}
	{% if is_disconnected %}
	RESPOND TYPE=error MSG='Cartographer is not connected, aborting calibration!'
	{% elif verify_firmware and 'K1' not in mcu_version and 'Lite' not in mcu_version %}
	RESPOND TYPE=error MSG="Axis Twist Compensation aborted: You must flash the cartographer with K1 specific firmware!"
	RESPOND TYPE=error MSG="See https://pellcorp.github.io/creality-wiki/invalid-cartographer-firmware"
	{% else %}
	{% if stop_start_camera %}
	STOP_CAMERA
	{% endif %}
	
	_CARTOGRAPHER_AXIS_TWIST_COMPENSATION USE_TOUCH_BOUNDARIES=1 {rawparams}
	
	{% if stop_start_camera %}
	RESPOND TYPE=command MSG='You need to run START_CAMERA on completion'
	{% endif %}
	{% endif %}

[gcode_macro _CARTOGRAPHER_QUICKSTART]
variable_stop_start_camera = False
variable_heat_nozzle = True
gcode = 
	{% set preheat_nozzle_temp = printer["gcode_macro _START_END_PARAMS"].start_preheat_nozzle_temp %}
	{% if heat_nozzle %}
	M104 S{preheat_nozzle_temp}
	{% endif %}
	{% set camera_started = printer["gcode_macro START_CAMERA"].started|default(true) %}
	{% if stop_start_camera and camera_started %}
	STOP_CAMERA
	{% endif %}
	{% if "xy" not in printer.toolhead.homed_axes %}
	G28 X Y
	{% endif %}
	{% if heat_nozzle %}
	M109 S{preheat_nozzle_temp}
	G4 P10000
	{% endif %}
	CARTOGRAPHER_TOUCH_CALIBRATE MAX=5000
	CARTOGRAPHER_TOUCH_HOME
	CARTOGRAPHER_SCAN_CALIBRATE METHOD=touch
	{% if stop_start_camera and camera_started %}
	START_CAMERA
	{% endif %}
	RESPOND TYPE=command MSG='Saving config and restarting klipper'
	SAVE_CONFIG

