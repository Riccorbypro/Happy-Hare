[gcode_macro M109]
rename_existing = M99109
variable_min_range = 1.0
variable_max_range = 1.0
gcode = 
	{% set s = params.S|float %}
	M104 S{s}
	
	{% if s != 0 %}
	{% set current_temp = printer.extruder.temperature %}
	{% if current_temp < s or current_temp > s+1 %}
	{% if printer["gcode_macro _SAF_HEATING_NOZZLE_START"] != null %}
	_SAF_HEATING_NOZZLE_START
	{% endif %}
	RESPOND TYPE=command MSG='Waiting for nozzle temp to reach {s}c'
	{% endif %}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={s - min_range} MAXIMUM={s + max_range}
	
	{% if printer["gcode_macro _SAF_HEATING_NOZZLE_END"] != null %}
	_SAF_HEATING_NOZZLE_END
	{% endif %}
	{% endif %}

[gcode_macro M190]
rename_existing = M99190
variable_min_range = 1.0
variable_max_range = 1.0
gcode = 
	{% set s = params.S|float %}
	M140 S{s}
	
	{% if s != 0 %}
	{% set current_temp = printer.heater_bed.temperature %}
	{% if current_temp < s or current_temp > s+1 %}
	{% if printer["gcode_macro _SAF_HEATING_BED_START"] != null %}
	_SAF_HEATING_BED_START
	{% endif %}
	RESPOND TYPE=command MSG='Waiting for bed temp to reach {s}c'
	{% endif %}
	TEMPERATURE_WAIT SENSOR=heater_bed MINIMUM={s - min_range} MAXIMUM={s + max_range}
	
	{% if printer["gcode_macro _SAF_HEATING_BED_END"] != null %}
	_SAF_HEATING_BED_END
	{% endif %}
	{% endif %}

[gcode_macro INPUT_SHAPER]
description = Run shaper calibrate and choose default shapers
gcode = 
	{% if printer.print_stats.state != "printing" %}
	{% if 'resonance_tester' in printer.configfile.settings %}
	{% set kinematics = printer.configfile.settings['printer'].kinematics %}
	{% set axis = params.AXIS | default('') | upper %}
	{% if kinematics != 'cartesian' or axis == 'X' or axis == 'Y' %}
	{% if "xyz" not in printer.toolhead.homed_axes %}
	G28
	{% endif %}
	{% if axis != '' %}
	SHAPER_CALIBRATE AXIS={axis}
	{% else %}
	SHAPER_CALIBRATE
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='You must specify an AXIS (X or Y)'
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='Resonance tester configuration missing!'
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='Not available while printing'
	{% endif %}

[gcode_macro INPUT_SHAPER_GRAPHS]
variable_shapers = "zv,mzv,zvd,ei,2hump_ei,3hump_ei"
description = Generate Input Shaper Graphs
gcode = 
	{% if printer.print_stats.state != "printing" %}
	{% if 'resonance_tester' in printer.configfile.settings %}
	{% set kinematics = printer.configfile.settings['printer'].kinematics %}
	{% set axis = params.AXIS | default('') | upper %}
	
	{% if kinematics != 'cartesian' or axis == 'X' or axis == 'Y' %}
	{% if "xyz" not in printer.toolhead.homed_axes %}
	G28
	{% endif %}
	
	{% if axis == 'X' or axis == '' %}
	TEST_RESONANCES AXIS=X NAME=a
	M400
	{% endif %}
	
	{% if axis == 'Y' or axis == '' %}
	TEST_RESONANCES AXIS=Y NAME=b
	M400
	{% endif %}
	
	
	{% if axis == 'X' or axis == '' %}
	RESPOND TYPE=command MSG='Generating X graph, please wait ...'
	RUN_SHELL_COMMAND CMD=calibrate_shaper PARAMS="--shapers {shapers} $TMPDIR/resonances_x_a.csv -o $HOME/printer_data/config/images/resonances_x.png"
	{% endif %}
	
	{% if axis == 'Y' or axis == '' %}
	RESPOND TYPE=command MSG='Generating Y graph, please wait ...'
	RUN_SHELL_COMMAND CMD=calibrate_shaper PARAMS="--shapers {shapers} $TMPDIR/resonances_y_b.csv -o $HOME/printer_data/config/images/resonances_y.png"
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='You must specify an AXIS (X or Y)'
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='Resonance tester configuration missing!'
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='Not available while printing'
	{% endif %}

