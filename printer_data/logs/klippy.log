gcode = 

[gcode_macro PRINT_START]
variable_prepare = 0
gcode = 
	CLEAR_PAUSE
	
	{% set bed_temp = 60|float %}
	{% set extruder_temp = 220|float %}
	{% set chamber_temp = 0|int %}
	{% set tool = 0|int %}
	
	{% if 'BED_TEMP' in params|upper and (params.BED_TEMP|float) %}
	{% set bed_temp = params.BED_TEMP %}
	{% endif %}
	
	{% if 'EXTRUDER_TEMP' in params|upper and (params.EXTRUDER_TEMP|float) %}
	{% set extruder_temp = params.EXTRUDER_TEMP %}
	{% endif %}
	
	{% if 'CHAMBER_TEMP' in params|upper and (params.CHAMBER_TEMP|int) %}
	{% set chamber_temp = params.CHAMBER_TEMP %}
	{% endif %}
	
	{% if 'TOOL' in params|upper and (params.TOOL|int) %}
	{% set tool = params.TOOL %}
	{% endif %}
	
	M140 S{bed_temp}
	M141 S{chamber_temp}
	T{tool}
	M104 S140
	M106 S255
	G28
	G90
	
	G0 Z10 F3000
	WIPE_NOZZLE
	M106 S255
	M190 S{bed_temp}
	M109 S140
	M106 S0
	
	BED_MESH_CALIBRATE ADAPTIVE=1
	CARTOGRAPHER_TOUCH_HOME
	
	_SMART_PARK
	M109 S{extruder_temp}
	RESPOND TYPE=command MSG="Purging nozzle..."
	
	SET_PRINTER_STATE STATE=printing
	_LINE_PURGE
	SET_VELOCITY_LIMIT ACCEL={printer.configfile.settings.printer.max_accel}

[gcode_macro PRINT_END]
gcode = 
	M400
	G92 E0
	G1 E-10.0 F3600
	G91
	G0 Z1.00 X5.0 Y5.0 F20000
	TURN_OFF_HEATERS
	M107
	G1 Z2 F3000
	G90
	G0 X295 Y150 F6000
	{% if printer.toolhead.position.z < 160 %}
	G0 Z160 F1200
	{% endif %}
	
	M84
	SET_PRINTER_STATE STATE=complete

