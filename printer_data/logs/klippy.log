	{% if "xy" not in printer.toolhead.homed_axes %}
	G28 X Y
	{% endif %}
	G90
	G0 Y200 F3600
	G0 X200 F6000
	G0 X42 F6000
	G0 X42 Y240 F6000
	SET_VELOCITY_LIMIT ACCEL=30000
	G0 E-2 F120
	G0 X42 Y301 F18000
	G0 Y240 F3600
	G0 E-3 F120
	G0 X42 Y301 F18000
	G0 Y240 F3600
	SET_VELOCITY_LIMIT ACCEL={printer.configfile.settings.printer.max_accel}

