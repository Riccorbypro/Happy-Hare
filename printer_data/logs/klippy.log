layers = static 0 0 top (0,0,1)

[mmu_led_effect mmu_ready_blue]
define_on = gates
layers = breathing 2 0 add (0,0,0.5)
	static 0 0 top (0,0,0)

[mmu_led_effect mmu_static_black]
define_on = gates
layers = static 0 0 top (0,0,0)

[mmu_led_effect mmu_rainbow]
