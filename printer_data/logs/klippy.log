[gcode_macro LOAD_FILAMENT]
variable_extruder_temp = 230
variable_extrude_len = 90
gcode = 
	{% if printer.print_stats.state != "printing" %}
	{% set EXTRUDER_TEMP = params.EXTRUDER_TEMP|default(extruder_temp)|int %}
	{% set EXTRUDE_LEN = params.EXTRUDE_LEN|default(extrude_len)|int %}
	{% set target_nozzle_temp = printer[printer.toolhead.extruder].target %}
	
	M109 S{EXTRUDER_TEMP}
	_CLIENT_LINEAR_MOVE E={EXTRUDE_LEN} F=180
	M400
	
	
	SET_STEPPER_ENABLE STEPPER=extruder ENABLE=0
	BEEP
	{% if target_nozzle_temp != EXTRUDER_TEMP %}
	M104 S{target_nozzle_temp}
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='Not available while printing'
	{% endif %}

[gcode_macro UNLOAD_FILAMENT]
variable_extruder_temp = 230
variable_extrude_len = 20
variable_extrude_speed = 180
variable_initial_retract_len = 50
variable_initial_retract_speed = 180
variable_retract_len = 30
variable_retract_speed = 2000
gcode = 
	{% if printer.print_stats.state != "printing" %}
	{% set EXTRUDER_TEMP = params.EXTRUDER_TEMP|default(extruder_temp)|int %}
	{% set target_nozzle_temp = printer[printer.toolhead.extruder].target %}
	
	M109 S{EXTRUDER_TEMP}
	SAVE_GCODE_STATE NAME=_client_movement
	M83
	{% if extrude_len > 0 %}
	G1 E{extrude_len} F{extrude_speed}
	{% endif %}
	G4 P500
	{% if initial_retract_len > 0 %}
	G1 E-{initial_retract_len} F{initial_retract_speed}
	{% endif %}
	G4 P500
	{% if retract_len > 0 %}
	G1 E-{retract_len} F{retract_speed}
	{% endif %}
	RESTORE_GCODE_STATE NAME=_client_movement
	
	M400
	
	
	SET_STEPPER_ENABLE STEPPER=extruder ENABLE=0
	BEEP
	{% if target_nozzle_temp != EXTRUDER_TEMP %}
	M104 S{target_nozzle_temp}
	{% endif %}
	{% else %}
	RESPOND TYPE=error MSG='Not available while printing'
	{% endif %}

[gcode_macro _DISCONNECT_PROBE]
gcode = 
	{% if printer["mcu scanner"] != null %}
	RESPOND TYPE=command MSG='Disconnecting Cartographer probe!'
	RUN_SHELL_COMMAND CMD=usbreset PARAMS="cartographer"
	{% elif printer["mcu cartographer"] != null %}
	RESPOND TYPE=command MSG='Disconnecting Cartographer probe!'
	RUN_SHELL_COMMAND CMD=usbreset PARAMS="cartographer"
	{% elif printer["mcu eddy"] != null %}
	RESPOND TYPE=command MSG='Disconnecting BTT Eddy probe!'
	RUN_SHELL_COMMAND CMD=usbreset PARAMS="eddy"
	{% elif printer["beacon"] != null %}
	RESPOND TYPE=command MSG='Disconnecting beacon probe!'
	RUN_SHELL_COMMAND CMD=usbreset PARAMS="beacon"
	{% endif %}

[gcode_macro _SET_KIN_MAX_Z]
gcode = 
	{% if "xy" not in printer.toolhead.homed_axes %}
	G28 X Y
	{% endif %}
	
	{% set max_z = printer.toolhead.axis_maximum.z - 35 %}
	RESPOND TYPE=command MSG='Setting fake Z Height of {max_z}'
	SET_KINEMATIC_POSITION Z={max_z}

[gcode_macro _CALIBRATE_PRE_HEAT]
variable_extruder_temp = 150
variable_bed_temp = 60
gcode = 
	{% set EXTRUDER_TEMP = params.EXTRUDER_TEMP|default(extruder_temp)|int %}
	{% set BED_TEMP = params.BED_TEMP|default(bed_temp)|int %}
	
	M140 S{BED_TEMP}
	M104 S{EXTRUDER_TEMP}
	M190 S{BED_TEMP}
	M109 S{EXTRUDER_TEMP}

[gcode_macro _CALIBRATE_HEAT_SOAK]
variable_heat_soak_wait_multiplier = 8.0
variable_heat_soak_wait_interval = 15
gcode = 
	{% set extruder_temp = printer["gcode_macro _CALIBRATE_PRE_HEAT"].extruder_temp %}
	{% set bed_temp = printer["gcode_macro _CALIBRATE_PRE_HEAT"].bed_temp %}
	{% set EXTRUDER_TEMP = params.EXTRUDER_TEMP|default(extruder_temp)|int %}
	{% set BED_TEMP = params.BED_TEMP|default(bed_temp)|int %}
	
	M140 S{BED_TEMP}
	M104 S{EXTRUDER_TEMP}
	
	{% if "xy" not in printer.toolhead.homed_axes %}
	G28 X Y
	{% endif %}
	
	M190 S{BED_TEMP}
	M109 S{EXTRUDER_TEMP}
	
	{% set total_time = (BED_TEMP * heat_soak_wait_multiplier)|int %}
	RESPOND TYPE=command MSG='Heat soak starting with a total time of {total_time} seconds...'
	{% set loops = (total_time / heat_soak_wait_interval)|int %}
	{% for i in range(loops) %}
	{% set time_remaining = total_time - (i + 1) * heat_soak_wait_interval %}
	RESPOND TYPE=command MSG='Heat soak { time_remaining } seconds remaining'
	{% if time_remaining < heat_soak_wait_interval %}
	G4 P{ time_remaining * 1000 }
	{% else %}
	G4 P{ heat_soak_wait_interval * 1000 }
	{% endif %}
	{% endfor %}
	RESPOND TYPE=command MSG='Heat soak finished!'

[gcode_macro G28]
rename_existing = G28.1
gcode = 
	SET_PRINTER_STATE STATE=homing
	G28.1 { rawparams }
	SET_PRINTER_STATE STATE=idle

