layers = chase 1 .5 top (0,0,1), (0,0,.4)

[mmu_led_effect mmu_blue_anticlock_slow]
define_on = gates, status
layers = chase -.5 .5 top (0,0,1), (0,0,.4)

[mmu_led_effect mmu_blue_anticlock_fast]
