	SET_PRINTER_STATE STATE=homing
	G28.1 { rawparams }
	SET_PRINTER_STATE STATE=idle

[homing_override]
axes = xyz
gcode = 
	G90
	{% set flag_O = params.O|default("false") %}
	{% set flag_X = params.X|default("false") %}
	{% set flag_Y = params.Y|default("false") %}
	{% set flag_Z = params.Z|default("false") %}
	{% if (flag_Y == "false" and flag_X == "false" and flag_Z == "false") %}
	{% set flag_X = "true" %}
	{% set flag_Y = "true" %}
	{% set flag_Z = "true" %}
	{% endif %}
	{% if flag_O !="false" and 'x' in printer.toolhead.homed_axes %}
	{% set flag_X = "false" %}
	{% endif %}
	{% if flag_O !="false" and 'y' in printer.toolhead.homed_axes %}
	{% set flag_Y = "false" %}
	{% endif %}
	{% if flag_O !="false" and 'z' in printer.toolhead.homed_axes %}
	{% set flag_Z = "false" %}
	{% endif %}
	
	{% if (flag_X !="false" or flag_Y !="false" or flag_Z !="false") %}
	{% if 'z' not in printer.toolhead.homed_axes %}
	FORCE_MOVE STEPPER=stepper_z DISTANCE=10 VELOCITY=10
	{% else %}
	G91
	G0 Z10 F600
	G90
	{% endif %}
	{% endif %}
	{% if (flag_Y != "false") or ((flag_X != "false" or flag_Z != "false") and 'y' not in printer.toolhead.homed_axes) %}
	_SENSORLESS_HOME_Y
	{% endif %}
	{% if (flag_X != "false") or (flag_Z != "false" and 'x' not in printer.toolhead.homed_axes) %}
	G0 Y30 F3600
	_SENSORLESS_HOME_X
	G0 X220 F3600
	_SENSORLESS_HOME_Y
	{% endif %}
	{% if flag_Z != "false" %}
	G0 X150 Y150 F3600
	G28.1 Z
	G0 Z10 F1800
	{% endif %}

[gcode_macro _SENSORLESS_HOME_Y]
gcode = 
	{% set HOME_CUR_X = 0.3 %}
	{% set HOME_CUR_Y = 0.3 %}
	{% set RUN_CUR_X = printer.configfile.settings['tmc5160 stepper_x'].run_current %}
	{% set RUN_CUR_Y = printer.configfile.settings['tmc5160 stepper_y'].run_current %}
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={HOME_CUR_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={HOME_CUR_Y}
	
	G4 P2000
	
	G28.1 Y
	
	G90
	G1 Y0 F1200
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={RUN_CUR_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={RUN_CUR_Y}

[gcode_macro _SENSORLESS_HOME_X]
gcode = 
	{% set HOME_CUR_X = 0.3 %}
	{% set HOME_CUR_Y = 0.3 %}
	{% set RUN_CUR_X = printer.configfile.settings['tmc5160 stepper_x'].run_current %}
	{% set RUN_CUR_Y = printer.configfile.settings['tmc5160 stepper_y'].run_current %}
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={HOME_CUR_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={HOME_CUR_Y}
	
	G4 P2000
	
	G28.1 X
	
	G90
	G1 X300 F1200
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={RUN_CUR_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={RUN_CUR_Y}

