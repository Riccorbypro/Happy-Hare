	MMU_TTG_MAP {rawparams}

[gcode_macro MMU_FORM_TIP]
description = Alias for updated macro name of MMU_TEST_FORM_TIP
gcode = 
	MMU_TEST_FORM_TIP {rawparams}

[gcode_macro _MMU_PRINT_START]
description = Alias for updated macro name of MMU_PRINT_START
gcode = 
	MMU_PRINT_START {rawparams}

[gcode_macro _MMU_PRINT_END]
description = Alias for updated macro name of MMU_PRINT_END
gcode = 
	MMU_PRINT_END {rawparams}

[gcode_macro _MMU_UPDATE_HEIGHT]
description = Alias for updated macro name of MMU_UPDATE_HEIGHT
gcode = 
	MMU_UPDATE_HEIGHT {rawparams}

[gcode_macro _MMU_ACTION_CHANGED]
description = Called when an action has changed
gcode = 
	{% set vars = printer['gcode_macro _MMU_STATE_VARS'] %}
	{% set action = params.ACTION|string %}
	{% set old_action = params.OLD_ACTION|string %}
	
	{% if not vars.user_action_changed_extension == "" %}
	{vars.user_action_changed_extension} {rawparams}
	{% endif %}

[gcode_macro _MMU_PRINT_STATE_CHANGED]
description = Called when print state changes
gcode = 
	{% set vars = printer['gcode_macro _MMU_STATE_VARS'] %}
	{% set state = params.STATE|string %}
	{% set old_state = params.OLD_STATE|string %}
	
	{% if not vars.user_print_state_changed_extension == "" %}
	{vars.user_print_state_changed_extension} {rawparams}
	{% endif %}

[gcode_macro _MMU_EVENT]
description = Called when certain MMU actions occur
gcode = 
	{% set vars = printer['gcode_macro _MMU_STATE_VARS'] %}
	{% set servo_down_limit = vars.servo_down_limit|default(-1)|int %}
	{% set cutter_blade_limit = vars.cutter_blade_limit|default(-1)|int %}
	{% set event = params.EVENT|string %}
	
	{% if event == "restart" %}
	MMU_STATS COUNTER=mmu_restarts INCR=1
	
	{% set vendor = printer.configfile.config.mmu_machine.mmu_vendor|string|lower %}
	{% set version = printer.configfile.config.mmu_machine.mmu_version|string|lower %}
	{% if vendor == "ercf" %}
	MMU_STATS COUNTER=servo_down LIMIT={servo_down_limit} WARNING="Inspect servo arm for wear/damage"
	MMU_STATS COUNTER=cutter_blade LIMIT={cutter_blade_limit} WARNING="Inspect/replace filament cutting blade"
	{% elif vendor == "tradrack" %}
	MMU_STATS COUNTER=servo_down LIMIT={servo_down_limit} WARNING="Inspect servo mechanism for wear/damage"
	MMU_STATS COUNTER=cutter_blade LIMIT={cutter_blade_limit} WARNING="Inspect/replace filament cutting blade"
	{% endif %}
	
	{% elif event == "gate_map_changed" %}
	{% elif event == "filament_gripped" %}
	MMU_STATS COUNTER=servo_down INCR=1
	{% elif event == "filament_cut" %}
	MMU_STATS COUNTER=cutter_blade INCR=1
	{% endif %}
	
	{% if not vars.user_mmu_event_extension == "" %}
	{vars.user_mmu_event_extension} {rawparams}
	{% endif %}

[exclude_object]

[force_move]
enable_force_move = True

[idle_timeout]
timeout = 172800

[gcode_arcs]
resolution = 1.0

[mcu]
serial = /dev/serial/by-id/usb-Klipper_stm32h723xx_1A003F000D51333235363331-if00

[printer]
kinematics = corexy
max_velocity = 800
max_accel = 40000
max_z_velocity = 25
max_z_accel = 350
square_corner_velocity = 5.0

[temperature_sensor catalyst_mcu_temp]
sensor_type = temperature_mcu
min_temp = 0
max_temp = 100

[temperature_sensor BTT_Pi_temp]
sensor_type = temperature_host
sensor_path = /sys/class/thermal/thermal_zone0/temp
min_temp = -10
max_temp = 90

[heater_bed]
heater_pin = !PB0
sensor_type = EPCOS 100K B57560G104F
sensor_pin = PC0
min_temp = 0
max_temp = 125
control = pid
pid_kp = 19.106
pid_ki = 0.743
pid_kd = 122.754
pid_version = 1
pid_target = 70.00
pid_tolerance = 0.0200

[screws_tilt_adjust]
screw1 = 19,23
screw1_name = front left
screw2 = 278,23
screw2_name = front right
screw3 = 248,272
screw3_name = rear right
screw4 = 50,272
screw4_name = rear left
horizontal_move_z = 10
speed = 200
screw_thread = CW-M4

[temperature_fan chamber_fan]
pin = PA1
cycle_time = 0.0100
hardware_pwm = false
max_power = 1.0
shutdown_speed = 0.0
sensor_type = EPCOS 100K B57560G104F
sensor_pin = PC1
min_temp = 0
max_temp = 70
control = watermark
max_delta = 2
target_temp = 35.0
max_speed = 1.0
min_speed = 0.0

[controller_fan _driver_fan]
pin = PB2
max_power = 1.0
shutdown_speed = 1.0
kick_start_time = 1.0
idle_speed = 0.7
idle_timeout = 120
stepper = stepper_x, stepper_y, stepper_z

[temperature_fan _board_fan]
pin = PB2
sensor_type = temperature_mcu
max_power = 1.0
shutdown_speed = 1.0
kick_start_time = 0.5
min_speed = 0.3
control = watermark
max_delta = 5
min_temp = -10
max_temp = 90
target_temp = 50

[temperature_fan _pi_fan]
pin = PA0
tachometer_pin = PC2
sensor_type = temperature_host
sensor_path = /sys/class/thermal/thermal_zone0/temp
max_power = 1.0
shutdown_speed = 1.0
kick_start_time = 0.5
min_speed = 0.3
control = watermark
max_delta = 5
min_temp = -10
max_temp = 90
target_temp = 50

[fan_generic exhaust_fan]
pin = PA1
cycle_time = 0.0100
kick_start_time = 0.5
max_power = 1.0

[fan_generic ouglesauce]
pin = PB3
cycle_time = 0.0100
kick_start_time = 1.0
max_power = 1.0

[heater_generic chamber]
heater_pin = PC8
max_power = 1.0
sensor_type = EPCOS 100K B57560G104F
sensor_pin = PC1
control = watermark
max_delta = 1
min_temp = 0
max_temp = 65

[verify_heater chamber]
max_error = 900
check_gain_time = 300
hysteresis = 50
heating_gain = 1

[output_pin LED]
pin = PA15
pwm = True
cycle_time = 0.010
value = 1

[telemetry]
enabled = True

[probe_eddy_ng btt_eddy]
calibrated_drive_currents = 15, 16
calibration_version = 5
reg_drive_current = 15
tap_drive_current = 16
calibration_15 = 
calibration_16 = 

[cartographer touch_model default]
threshold = 792
speed = 2
z_offset = -0.05
software_version = 1.6.0
mcu_version = CARTOGRAPHER V4 6.1.0

[cartographer scan_model default]
coefficients = 1.5218034511326857,2.013462066971556,0.8609044572672884,0.4006556604711059,0.31731922953202624,0.37215970554975764,-0.09555475825157639,-0.32099060358237197,0.19638424062458662,0.24339159591219928
domain = 3.337132493057779e-07,3.4514352654126306e-07
z_offset = 0
reference_temperature = 43.18
software_version = 1.6.0
mcu_version = CARTOGRAPHER V4 6.1.0

[cartographer coil]
calibration = 2.191260273026277e-05,10.540187732088915,0.0,-1.5e-323
