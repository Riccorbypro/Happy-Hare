timeout = 90.0
verbose = True

[neopixel _status_bar]
pin = PD3
chain_count = 31
initial_red = 0.0
initial_green = 0.0
initial_blue = 0.0
color_order = GRB

[gcode_macro SET_PRINTER_STATE]
gcode = 
	{% set state = 'idle' %}
	{% set fadetime = 1.0|float %}
	{% if 'STATE' in params|upper and (params.STATE|string) %}
	{% set state = params.STATE %}
	{% endif %}
	{% if 'FADE' in params|upper and (params.FADE|float) %}
	{% set state = params.FADE %}
	{% endif %}
	SET_LED_EFFECT EFFECT={state} FADETIME={fadetime} REPLACE=1
	{% if state == 'complete' %}
	UPDATE_DELAYED_GCODE ID=return_to_idle DURATION=180
	{% endif %}

[delayed_gcode return_to_idle]
gcode = 
	SET_PRINTER_STATE STATE=idle

[led_effect idle]
autostart = true
frame_rate = 24
leds = 
	neopixel:_status_bar
heater = heater_bed
layers = 
	
	breathing      16 1     screen     (.2,.1,.6)
	static         1  0     top        (0,.15,.5)

[led_effect homing]
frame_rate = 24
autostart = false
leds = 
	neopixel:_status_bar
layers = 
	cylon          1   0     screen     ( 0.5,   0.5,   0.0  )
	breathing      3   0     top        ( 0.25,  0.25,  0.0  )

[led_effect meshing]
frame_rate = 24
autostart = false
leds = 
	neopixel:_status_bar
layers = 
	chase 1.50  2.00 add (1.00,1.00,1.00),(1.00,0.00,0.00),(0.0,0.0,0.0)
	chase -1.50 2.00 add (1.00,1.00,1.00),(0.00,0.00,1.00),(0.0,0.0,0.0)

[led_effect preheat]
frame_rate = 24
autostart = false
leds = 
	neopixel:_status_bar
heater = heater_bed
layers = 
	heaterfire      1  0    top         ( 0.1,  0.25,  0.5  ),( 1,    0.5,   0.0  )

[led_effect printing]
